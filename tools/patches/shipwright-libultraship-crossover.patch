+void ArchiveManager::SetArchivesPreserveLoaded(std::shared_ptr<std::vector<std::shared_ptr<Archive>>> archives) {
+    const auto gameVersions = mGameVersions;
+    mArchives.clear();
+    mHashes.clear();
+    mDirectories.clear();
+    mFileToArchive.clear();
+
+    if (!archives) {
+        mGameVersions.clear();
+        return;
+    }
+
+    for (const auto& archive : *archives) {
+        if (archive == nullptr || !archive->IsLoaded()) {
+            continue;
+        }
+
+        mArchives.push_back(archive);
+
+        const auto fileList = archive->ListFiles();
+        for (auto& [hash, filename] : *fileList.get()) {
+            mHashes[hash] = filename;
+            mFileToArchive[hash] = archive;
+
+            size_t lastSlash = filename.find_last_of('/');
+            if (lastSlash != std::string::npos) {
+                std::string dir = filename.substr(0, lastSlash);
+                mDirectories.insert(dir);
+            }
+        }
+    }
+
+    mGameVersions = gameVersions;
+}
+
